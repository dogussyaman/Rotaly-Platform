NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here

# Sadece backend tarafında kullanılacak, CLIENT'A ASLA VERME
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Uygulama temel URL'si
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Google OAuth ayarları için referans (Supabase paneline gireceksin)
# Supabase → Authentication → Providers → Google
# Client ID ve Client Secret'ı oraya yazacaksın, .env'ye eklemen gerekmiyor.

# Eğer özel bir redirect route kullanırsan, Supabase panelinde Redirect URL olarak:
#   http://localhost:3000/auth/callback
# veya production domain:
#   https://rotaly.com/auth/callback

